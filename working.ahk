			{
				if (A_LoopField = "")
					{
						continue
					}
				ifnotinstring,omitxtv,`,%A_LoopField%
					{
						if (omitxtc = "")
							{
								omitxtc.= A_LoopField
								continue
							}
						omitxtc.= "," . A_LoopField
						ifnotinstring,omitxtv,%A_LoopField%
							{
								if (A_LoopField = "zip")
									{
										if (noinclz <> 1)
											{
												omitxtc:= A_LoopField . "," . omitxtc											
											}
									}
								else {
										omitxtc:= A_LoopField . "," . omitxtc									
									}
							ifnotinstring,allxtn,%A_LoopField%
								{
									allxtn.= A_LoopField . ","
								}		
							}
					}
			}
		omitxtv:= omitxtc . "," . omitxtv
		stringreplace,omitxtv,omitxtv,.,,All
	}

