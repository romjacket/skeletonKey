							stringsplit,avn,a_Loopreadline,(),%A_Space%
							stringsplit,axn,a_Loopreadline,.,%A_Space%
							if (splsys1 = mamename)
								{
									medtyp:= avn2
									fnd+=1
								}
							tmpmed:= avn2
									if (tmpmed <> medtyp)
										{
											fnd+=1
											newxtlst=
										}
