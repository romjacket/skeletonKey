;{;;;;;;;;;;;;;;;;;;;;;;;   MAME  ;;;;;;;;;;;;;;;;;;
;{;;;;;;;;;;;;  MAME SHOW HIDE GUI  ;;;;;;;;;;;;;;;
MAMEGUITOG:
Loop,Parse,MAMEGUIITEMS,|
	{
		guicontrol,%fndtog%,%A_LoopField%
	}
return
