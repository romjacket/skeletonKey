			{
				stringreplace,viv3,viv3,%aik2%,,All
			}
		vov= %viv3%
		if (vov <> "")
			{
				if (vov <> emjddlb)
					{
						continue
					}
			}
			else {
				vov= x
			}
		kvir1=
		kvir2=
		kvir3=
		kvir4=
		kvir5=
		kvir6=
		stringsplit,kvir,aik3,_,"
		;"
		plnumb=
		Loop, %kvir0%
			{
				if (A_Index = 1)
					{
						mamenjk= % (kvir%a_index%)
						stringtrimleft,plnumb,mamenjk,1
						continue
					}
				mamenvx= % (kvir%a_index%)
				mamenvl.= "_" . mamenvx
			}
		if (plnumb <> emjddlb)
				{
					if (vov <> "x")
						{
							continue
						}
					else {
						plnumb= %emjddlb%
					}
				}
		if (kvir2 = "")
			{
				mamenvl= _%kvir1%
