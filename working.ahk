abarb= |
SB_SetText("Loading snes9x options")
Loop, Parse, snes9xHopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		snvo1=
		snvo2=
		stringsplit,snvo,A_LoopField,=
		if (snvo1 = "SuperFXClockMultiplier")
			{
				guicontrol,,emuCHKC,1
				guicontrol,,emuCBXB,%snvo2%
			}
	}
Loop, Parse, snes9xRopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		snvo1=
		snvo2=
		stringsplit,snvo,A_LoopField,=
		svi= 1
		if (snvo1 = "Cheat")
			{
				if (snvo2 = "FALSE")
					{
						svi= 0
					}
				guicontrol,,emuCHKO,%svi%
			}
		svi= 1
		if (snvo1 = "Patch")
			{
				if (snvo2 = "FALSE")
					{
						svi= 0
					}
				guicontrol,,emuCHKD,%svi%
			}
	}
Loop, Parse, snes9xSopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		snvo1=
		snvo2=
		stringsplit,snvo,A_LoopField,=
		kpv= 1
		if (snvo1 = "Sync")
			{
				if (snvo2 = 0)
					{
						kpv= 0
					}
				guicontrol,,emuCHKB,%kpv%
			}
		if (snvo1 = "Rate")
			{
				guicontrol,,emuCBXE,|%snvo2%||44100|48000|35000|32000|30000|22000|16000|11000|8000
			}
	}
Loop, Parse, snes9xSWopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		snvo1=
		snvo2=
		stringsplit,snvo,A_LoopField,=
		if (snvo1 = "SoundDriver")
			{
				if (snvo2 = 4)
					{
						guicontrol,,emuDDLH,|XAudio2||DirectSound|
					}
					else {
						guicontrol,,emuDDLH,|DirectSound||XAudio2
					}
			}
		if (snvo1 = "BufferSize")
			{
				GUICONTROL,,emuDDLF,|%snvo2%||16|32|48|64|80|96|112|128|144|160|176|194|210
			}
	}
Loop, Parse, snes9xNopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		snvo1=
		snvo2=
		stringsplit,snvo,A_LoopField,=
		if (snvo1 = "Port")
			{
				guicontrol,,emuedtd,%snvo2%
			}
		if (snvo1 = "MaxFrameSkip")
			{
				guicontrol,,emuedtf,%snvo2%
			}
		if (snvo1 = "MaxBehindFrameCount")
			{
				guicontrol,,emuedtg,%snvo2%
			}
		emucxt= 1
		if (snvo1 = "SendROMImageOnConnect")
			{
				if (snvo2 = "OFF")
					{
						emucxt= 0
					}
				guicontrol,,emuCHKg,%emucxt%
			}
		emucxt= 1
		if (snvo1 = "SyncByReset")
			{
				if (snvo2 = "OFF")
					{
						emucxt= 0
					}
				guicontrol,,emuCHKu,%emucxt%
			}
		emucxt= 1
		if (snvo1 = "RecentHost1")
			{
				if (snvo2 = "")
					{
						emucxt= 0
					}
				guicontrol,,emuCHKr,%emucxt%
			}
	}
Loop, Parse, snes9xDopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		snvo1=
		snvo2=
		stringsplit,snvo,A_LoopField,=
		emucxt= 1
		if (snvo1 = "Transparency")
			{
				if (snvo2 = "OFF")
					{
						emucxt= 0
					}
				guicontrol,,emuchkf,%emucxt%
			}
		emucxt= 1
