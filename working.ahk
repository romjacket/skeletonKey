			{
				gosub, R%crdub%
				if (DWNCNCL = 1)
					{
						break
					}
				continue
			}
		if (RALIST = 1)
			{
				bwSpeed=
				ifnotexist, coreavail.ini
					{
						gosub, CoreupdtChk
					}
				ifexist, coreavail.ini
					{
						bwSpeed= 1
					}
				if (bwSpeed = 1)
					{
						if (locfnd <> 1)
							{
								Loop, Read, coreavail.ini
									{
										if (A_LoopReadLine = coredll | ".zip")
											{
