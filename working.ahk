		ifinstring,emu_es,:
			{
				emushrtn= %emu_es%
			}
		iniread,arg_es,EScfg.ini,%sysesc%,arg_es
		iniread,rmp_es,EScfg.ini,%sysesc%,rmp_es
		iniread,thm_es,EScfg.ini,%sysesc%,thm_es
