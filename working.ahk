		iniwrite, "%EMPOSTRUN%",AppParams.ini,%sysni%,EMPOSTRUN
		iniwrite, "%EMPRERUN%",AppParams.ini,%sysni%,EMPRERUN
		iniwrite, "%EMPREW%",AppParams.ini,%sysni%,EMPREW
		iniwrite, "%EMPOSTW%",AppParams.ini,%sysni%,EMPOSTW
