				IniWrite,"%sysni%",Assignments.ini,OVERRIDES,%sysni%
				IniWrite,"%redefa%",Assignments.ini,ASSIGNMENTS,%sysni%
				IniRead,bjk,sets\AppParams.set,%sysni%
				Loop, Parse, bjk,`n`r
