nvar1=
nvar2=
stringsplit,nvar,EMDDLP,>
optn= %nvar2%
if (nvar2 = "")
	{
		optn=
		NEWFN=
		if (ADDFN <> "")
			{
				cnttot= 100
				cntdwn= 99
				curadd= 1
				Loop, 99
					{
						cnttot-=1
						cntdwn-=1
						stringreplace,ADDFN,ADDFN,>%cntdwn%,>%cnttot%,All
					}
				NEWFN.= ADDFT . ">" . "1" . "|" . ADDFN
				ADDAK= %NEWFN%
				prepnd= 1
			}
	}
if (prepnd = 1)
	{
		goto, emprepost
	}
adnm=
curadd=
Loop, Parse, ADDFN,|
	{
		if (A_LoopField = "")
			{
				continue
			}
		nvar1=
		nvar2=
		stringsplit,nvar,A_LoopField,>
		adnm+=1
		if (adnm = optn)
			{
				curadd:= adnm+1
				ADDAK.= nvar1 . ">" . adnm . "|" . ADDFT . ">" . curadd . "|"
				adnm+=1
				continue
			}
		ADDAK.= nvar1 . ">" . adnm . "|"
	}
