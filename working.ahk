medlkup=
rbab= |
Loop, Parse, emujoyopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		mdlnval= %A_LoopField%
		stringleft,skln,A_LoopField,1
		if (skln = ";")
			{
				continue
			}
		aik1=
		aik2=
		aik3=
		aik4=
		aik5=
		stringsplit,aik,A_LoopField,%A_Space%.
		if (curmedINPT <> aik4)
			{
				continue
			}
		stringright,curjport,aik3,1
		if (curjport <> emjDDLB)
			{
				continue
			}
		if ((aik1 = RJMEDNM)&&(aik2 = "input"))
			{
				Loop, Parse, supinp,|
					{
						if (aik4 <> A_LoopField)
							{
