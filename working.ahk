				if (A_LoopField = "")
					{
						continue
					}
				stringsplit,afin,A_LoopField,=
				Loop,Parse,afin2,|
					{
						if (A_LoopField = "")
							{
								continue
							}
						if (A_LoopField = sysni)
							{
								continue
							}
						vprse.= A_LoopField . "|"
					}
