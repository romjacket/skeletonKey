												else {
													stringsplit,fir,ksr,|
													ACSVDEST= %fir1%
												}
											;;ACSVDEST= %RJSYSTEMS%\%OVDFLDR%
										}
					}
					else
						{
							OVDCHK= 0
							OVDFLDR=
						}
				iniread,ksr,SystemLocations.ini,LOCATIONS,%romsys%
				if (ksr = "ERROR")
					{
						ksr=
					}
				if (ksr = "")
					{
						ACSVDEST= %RJSYSTEMS%\%romsys%
					}
					else {
						stringsplit,fir,ksr,|
						ACSVDEST= %fir1%
					}
				;;ACSVDEST= %RJSYSTEMS%\%romsys%
				JACKETMODE= %aprm2%
				EXTRURL= %aprm3%
				EXTEXPLD= %aprm4%
				RUNXTRACT= %aprm5%
				ARCMOVE= %aprm6%
				if (JACKETMODE = 1)
					{
						rjinsfldr= %romname%
						if (RNMJACK <> "")
							{
