	}
fileread,nwj,%nwmamejoycfg%
Loop,Parse,njw,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		ifinstring,A_LoopField,%RJMAMENM%.input
			{
				stringsplit,fi,A_loopField,%A_Space%
				stringreplace,nv,fi1,.,_,All
				Loop, %fi0%
					{
						if (A_index = 1)
							{
								continue
							}
						av= % fi%A_Index%
						if (A_index = 2)
							{
								mameinput.= nv . "=" . av
								continue
							}
						mameinput.= nv . A_space . av
					}
				mameinput.= "`n"
			}
	}
