PlayerType:
gui, submit, nohide
PLYRTYP= KB
gosub, HideInpBut
guicontrolget,CJsel,,JOYCORE
stringreplace,CJsel,CJSel,_libretro.dll,,All
guicontrolget, JSW,, JSW
if (JSW = 1)
	{
		PLYRTYP= J
		gosub, ShowInpBut
		jlex=
		try, gosub, core_%CJsel%JLayout
			catch
				{
					if (jlex = "")
						{
							gosub, DefaultJLayout
						}
				}
	}
gui, submit, nohide
gosub, PlyrDrpDwn
return
