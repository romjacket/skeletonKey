				guicontrol,show,emj%mameitbv%
				guicontrol,,emj%mameitbv%,|%rmpvsetj%||%mamejbid%
				TF_replaceline("!"mamejsysloc,mjnv,mjnv,rmpbtnvlfk "JOYCODE_1_" rmpbtnvlj "")
				kmj%mameitbv%= %mamenvl%
			}
		if (emjRAD3A = 1)  ;;kb
			{
				Loop, parse, mamekbctrls,`n`r
					{
						if (A_LoopField = "")
							{
								continue
							}
						jnam1=
						jnam2=
