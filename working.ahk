					{
						MAME_%bbvr%= %einv%
						mame_syst.= ecfsysn . "|"
						rev_%bbvr%= %ecfsysn%
						mamesplit.= einv . "|" . ecfsysn . "`n"
						mamad= 1
						break
					}
			}
	}
if (msyslist <> "")
	{
		afep= |
		Loop, Parse, mamesplit,`n`r
			{
				if (A_LoopField = "")
					{
						continue
					}
				stringsplit,ji,A_LoopField,|
				afep.= ji2 . "|"
				Loop,parse,mame_sysk,|
					{
						if (A_Loopfield = ji1)
							{
								mame_sys.= ji2 . "|"
								stringreplace,mame_sysk,mame_sysk,%ji1%|,,
								break
							}
					}
			}
		mame_sys.= mame_sysk
		sort,mame_sys, Alphabetically D|		
	}
return

