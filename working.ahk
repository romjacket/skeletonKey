			{
				goto, Arclaunch
			}
		coremsvc=
		iniread,RJMAMENM,sets\emuCfgPresets.set,%EXTRSYS%,RJMAMENM
		iniread,CUSTMOPT,AppParams.ini,%coreselv%,options
		stringreplace,CUSTMOPT,CUSTMOPT,",,All
		;"
