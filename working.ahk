Loop, Files, executable\*.*,RFD
	{
		ifinstring,utlitmz,%A_LoopFileFullPath%
			{
				continue
			}
		LV_Add(lvachk, A_LoopFileFullPath)
		utlitmz.= A_LoopFileFullPath . "|"
	}
LV_ModifyCol()
return
