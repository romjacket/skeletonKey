					{
						emucxt= 0
					}
				guicontrol,,emuchkE,%emucxt%
			}
	}
Loop, Parse, snes9xDWopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		snvo1=
		snvo2=
		stringsplit,snvo,A_LoopField,=
		vptx= DirectDraw
		if (snvo1 = "OutputMethod")
			{
				if (snvo2 = 1)
					{
						vptx= Direct3D
					}
				if (snvo2 = 2)
					{
						vptx= OpenGL
					}
				guicontrol,,emuDDLE,|%vptx%||OpenGL|DirectDraw|Direct3D
			}
		vpt= 1
		if (snvo1 = "Vsync")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKM,%vpt%
			}
		vpt= 1
		if (snvo1 = "Stretch:Enabled")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKT,%vpt%
			}
		vpt= 1
		if (snvo1 = "Stretch:MaintainAspectRatio")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKQ,%vpt%
			}
		vpt= 8:7
		if (snvo1 = "Stretch:AspectRatioBaseWidth")
			{
				if (snvo2 = "299")
					{
						vpt= 4:3
					}
				guicontrol,,emuDDLD,|%vpt%||8:7|4:3
			}
		vpt= 1
		if (snvo1 = "BlendHiRes")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKH,%vpt%
			}
		vpt= 1
		if (snvo1 = "Stretch:BilinearFilter")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKL,%vpt%
			}
		vpt= 1
		if (snvo1 = "ShaderEnabled")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKA,%vpt%
			}
		vpt= 1
		if (snvo1 = "Stretch:LocalVidMem")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKJ,%vpt%
			}
		vpt= 1
		if (snvo1 = "Fullscreen:DoubleBuffered")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKK,%vpt%
			}
		vpt= 1
		if (snvo1 = "Fullscreen:EmulateFullscreen")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKI,%vpt%
			}
		vpt= 1
		if (snvo1 = "ReduceInputLag")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKN,%vpt%
			}
		vpt= 1
		if (snvo1 = "Fullscreen:Enabled")
			{
				if (snvo2 = "FALSE")
					{
						vpt= 0
					}
				guicontrol,,emuCHKA,%vpt%
			}
		if (snvo1 = "Fullscreen:Width")
			{
				sn9xdr= %snvo2%x
			}
		if (snvo1 = "Fullscreen:Height")
			{
				sn9xdr.= snvo2 . A_Space
			}
		if (snvo1 = "Fullscreen:Depth")
			{
				sn9xdr.= snvo2 . "bit" . A_Space
			}
		if (snvo1 = "Fullscreen:RefreshRate")
			{
				sn9xdr.= snvo2 . "hz"
			}
		if (snvo1 = "Direct3D:D3DShader")
			{
				if (vptx <> "Direct3D")
					{
						continue
					}
				guicontrol,,emuEDTC,%snvo2%
			}
		if (snvo1 = "OpenGL:OGLShader")
			{
				if (vptx <> "OpenGL")
					{
						continue
					}
				guicontrol,,emuEDTC,%snvo2%
			}
		if (snvol1 = "FilterType")
			{
				vpt= None
				ptsv= Forced1X|Simple2X|Scanlines|TVMode|Blargg'sNTSC(Composite)|Blargg'sNTSC(S-Video)|Blargg'sNTSC(RGB)|SuperEagle|Super2xSaI|2xSaI|hq2x|hq2xS|hq2xBold|EPXA|EPXB|EPXC|Simple3X|TVMode3X|DotMatrix3X|hq3x|hq3xS|hq3xBold|lq3xBold|EPX3|Simple4X|hq4x|2xBRZ|3xBRZ|4xBRZ|5xBRZ|6xBRZ
				Loop,parse,ptsv,|
