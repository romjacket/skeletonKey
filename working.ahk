LOADMAMEOPTS:
core_gui= mame
;{;;;;;;;;;;;;;;;  Populate MAME GUI with Values  ;;;;;;;;;;;;;;;;;;;
abarb= |
SB_SetText("Loading mame options")
Loop, Parse, mameopts,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		stringleft,tmk,A_LoopField,1
		if (tmk = "#")
			{
				continue
			}
		nmv1=
		nmv2=
		nmv3=
		nmv4=
		nmv5=
		nmv6=
		stringsplit,nmv,A_LoopField,%A_Space%
		Loop,%nmv0%
			{
				if (A_index = 1)
					{
						MAME_%nmv1%=
						continue
					}
				MAME_%nmv1%.= nmv%A_Index%
			}
		nwmvtp= %nmv1%
		nwmvti= % MAME_%nmv1%
		if (nwmvtp = "autosave")
			{
				guicontrol,,emuCHKD,%nwmvti%
				continue
			}
		if (nwmvtp = "ui_active")
			{
				guicontrol,,emuCHKE,%nwmvti%
				continue
			}
		if (nwmvtp = "rewind")
			{
				guicontrol,,emuCHKE,%nwmvti%
				continue
			}
		if (nwmvtp = "rewind_capacity")
			{
				guicontrol,,emuSLDA,%nwmvti%
				guicontrol,,emuTXTL,%nwmvti% mb
				continue
			}
		if (nwmvtp = "bench")
			{
				guicontrol,,emuCHKG,%nwmvti%
				continue
			}
		if (nwmvtp = "prescale")
			{
				guicontrol,,emuCHKH,%nwmvti%
				if (nwmvti = 1)
					{
						guicontrol,,emuDDLG,|off||slot-mask|shadow-mask|arperture-grille
					}
				continue
			}
		if (nwmvtp = "maximize")
			{
				guicontrol,,emuCHKI,%nwmvti%
				continue
			}
		if (nwmvtp = "hwstretch")
			{
				guicontrol,,emuCHKJ,%nwmvti%
				continue
			}
		if (nwmvtp = "triplebuffer")
			{
				guicontrol,,emuCHKK,%nwmvti%
				continue
			}
		if (nwmvtp = "switchres")
			{
				guicontrol,,emuCHKL,%nwmvti%
				continue
			}
		if (nwmvtp = "waitvsync")
			{
				guicontrol,,emuCHKM,%nwmvti%
				continue
			}
		if (nwmvtp = "syncrefresh")
			{
				guicontrol,,emuCHKN,%nwmvti%
				continue
			}
		if (nwmvtp = "menu")
			{
				guicontrol,,emuCHKO,%nwmvti%
				continue
			}
		if (nwmvtp = "sound")
			{
				guicontrol,,emuCHKC,%nwmvti%
				if (nwmvti <> 0)
					{
						guicontrol,,emuCHKC,1
					}
				continue
			}
		if (nwmvtp = "throttle")
			{
				guicontrol,,emuCHKB,%nwmvti%
				continue
			}
		if (nwmvtp = "audiolatency")
			{
				guicontrol,,emuCBXE,|%nwmvti%||1|2|3
				continue
			}
		if (nwmvtp = "autoframeskip")
			{
				guicontrol,,emuCHKA,%nwmvti%
				continue
			}
		if (nwmvtp = "frameskip")
			{
				guicontrol,,emuCBXA,|%nwmvti%||1|2|3
				continue
			}
		if (nwmvtp = "samples")
			{
				guicontrol,,emuCBXB,|%nwmvti%||1|2|3
				continue
			}
		if (nwmvtp = "screennumber")
			{
				guicontrol,,emuCBXC,|%nwmvti%||0|1|2|3|4
				continue
			}
		if (nwmvtp = "numprocessors")
			{
				guicontrol,,emuCBXD,|%nwmvti%||auto|1|2|3|4|5|6|7|8
				continue
			}
		if (nwmvtp = "video")
			{
				guicontrol,,emuDDLE,|%nwmvti%||d3d|bgfx|auto|gdi|opengl|soft|accel
				ifinstring,nwmvti,bgfx
					{
						guicontrol,enable,emuddlc
					}
				continue
			}
		if (nwmvtp = "samplerate")
			{
				guicontrol,,emuDDLD,|%nwmvti%||48000|24000|8000
				continue
			}
		if (nwmvtp = "window")
			{
				guicontrol,,emuRad1B,1
				if (nwmvti = 1)
					{
						guicontrol,,emuRad1A,%nwmvti%
						guicontrol,disable,emuCHKK
					}
				continue
			}
		if (nwmvtp = "keepaspect")
			{
				guicontrol,,emuCHKQ,%nwmvti%
				continue
			}
		if (nwmvtp = "filter")
			{
				guicontrol,,emuCHKR,%nwmvti%
				continue
			}
			if (nwmvtp = "hlsl_preset")
			{
				guicontrol,,emuddlc,%nwmvti%
				continue
			}
		if (nwmvtp = "unevenstretch")
			{
				guicontrol,,emuCHKS,%nwmvti%
				continue
			}
		if (nwmvtp = "autostretchxy")
			{
				guicontrol,,emuCHKT,%nwmvti%
				continue
			}
		if (nwmvtp = "bgfx_screen_chains")
			{
				stringsplit,efik,nwmvti,`,%A_Space%
				guicontrol,,emuddlc,|%efik1%||hlsl|crt-geom-deluxe|crt-geom|default|hlsl|lut|pillarbox_left_horizontal|pillarbox_left_vertical|pillarbox_right_horizontal|pillarbox_right_vertical|unfiltered|super-eagle|hq2x|hq3x|hq4x|super-2xbr-3d-2p|super-2xbr-3d-3p-smoother|super-4xbr-3d-4p|super-4xbr-3d-6p-smoother|super-xbr-2p|super-xbr-3p-smoother|super-xbr-6p|super-xbr-deposterize|super-xbr-fast-3p|super-xbr-fast-6p|xbr-hybrid|xbr-lv1-noblend|xbr-lv2-3d|xbr-lv2-accuracy-multipass|xbr-lv2-accuracy-smart-blur|xbr-lv2-deposterize|xbr-lv2-fast|xbr-lv2-multipass|xbr-lv2-noblend|xbr-lv2|xbr-lv3-multipass|xbr-lv3-noblend|xbr-lv3|xbr-mlv4-dilation|xbr-mlv4-multipass
			}
		if (nwmvtp = "shadow_mask_texture")
			{
				stringreplace,fji,nwmvti,.png,,All
				guicontrol,,emuddlg,|%fji%||off|slot-mask|shadow-mask|arperture-grille
			}
		if (nwmvtp = "hlsl_enable")
			{
				if (nwmvti = 0)
					{
						guicontrol,,emuDDLG,|off||slot-mask|shadow-mask|arperture-grille
					}
			}
	}
SB_SetText("mame options loaded")
gosub, MameCTRLS
emutog= enable
Loop, parse, MAMEGUIITEMS,|
	{
		guicontrol,%emutog%,%A_LoopField%
	}
Loop,parse,RUNBOXGUIITEMS,|
	{
		guicontrol,%emutog%,%A_LoopField%
	}	
return
;};;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
