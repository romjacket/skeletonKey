nvar2=
stringsplit,nvar,EMDDLP,>
optnew= %nvar2%
IniRead, EMOPV,AppParams.ini,%sysni%,%CMDRO%
EMEDTW=
if (optn = "")
	{
		return
	}
if (EMEDTO = "")
	{
		EMEDTO= :
	}
opvn=
Loop, Parse, EMOPV,|
	{
		if (A_LoopField = "")
			{
