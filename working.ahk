;;;global export;;;;
Loop, parse, medglobal,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		aii1=
		aii2=
		inmk=
		stringsplit,aii,A_LoopField,=
		ifinstring,aii2,[
			{
				Loop, parse, medkeyb,`n`r
					{
						ifinstring,A_LoopField,%aii2%
							{
								FileAppend,%aii1% %A_LoopField%`n,%emucfgloc%
								inmk= 1
								continue
							}
					}
				if (inmk = 1)
					{
						continue
					}
				ifinstring,aii2,[ROMPATH]
					{
						stringreplace,aii2,aii2,[ROMPATH],%indvcp%,All
						FileAppend,%aii1% %aii2%`n,%emucfgloc%
						continue
					}
			}
		FileAppend,%aii1% %aii2%`n,%emucfgloc%
	}
;;;;system unique export;;;;
Loop, parse, medsysdef,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		aii1=
		aii2=
		stringsplit,aii,A_LoopField,=
		FileAppend,%aii1% %aii2%`n,%emucfgloc%
	}
;;;;common system export;;;;
Loop, parse, medcomn,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		aii1=
		aii2=
		stringsplit,aii,A_LoopField,=
		FileAppend,%aii1% %aii2%`n,%emucfgloc%
	}
;;;;input export;;;;
Loop, 16
	{
		jnum+= 1
		jvar=
		Loop, Parse, medjgrab,|
			{
				jman+= 1
				if (A_Index = jnum)
					{
						stringreplace,medinput,medinput,[0x0%jman%],%A_LoopField%,All
						jvar= %A_LoopField%
						medjid%jnum%= %A_LoopField%
						break
					}
			}
		if (jvar = "")
			{
				stringreplace,medinput,medinput,[0x0%A_Index%],0x0,All
				medjid%A_Index%= 0x0
			}
		medjindex= % medjid%A_index%
	}
Loop, parse, medinput,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		aii1=
		aii2=
		stringsplit,aii,A_LoopField,=
		api1=
		api2=
		stringsplit,api,aii1,.
		if (api1 = RJMEDNM)
			{
				FileAppend,%aii1%%A_Space%%aii2%`n,%emucfgloc%
			}
		if (RJMEDNM	= "")
			{
				FileAppend,%aii1%%A_Space%%aii2%`n,%emucfgloc%
			}
	}
return
