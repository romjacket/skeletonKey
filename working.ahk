Loop,Parse,EXTINP,`,
	{
		extenlist .= A_LoopField . "|"
	}
		if (extenlist = "")
			{
				iniwrite, "0",Assignments.ini,OVERRIDES,%OVLIST%
			}
iniwrite, "%extenlist%",Assignments.ini,EXTENSIONS,%OVLIST%
return
