			{
				mameitbv= B
			}
		if (mamenvl = mameswapA)
			{
				mameitbv= A
			}
		if (mamenvl = mameswapX)
			{
				mameitbv= X
			}
		if (mamenvl = mameswapY)
			{
				mameitbv= Y
			}
		if (mamenvl = mameswapSelect)
