FLCOR=
Loop,Parse, ovrnm,`n`r
	{
		if (A_LoopField = "")
			{
				continue
			}
		inran1=
		inran2=
		StringSplit,inran,A_LoopField,=,"
		;"
		stringsplit,aij,inran2,|
		inran2= %aij1%
		if (inran2 = LCORE)
			{
				FLCOR= %inran1%
				break
			}
	}
nicktst=
subemuname=
EMUFN=
EMUL=
EMUXTYP=
EMUSN=
EMUDRV=
emjDDLB=
cfginif= apps.ini
cfginik= EMULATORS
cfgemc= %RJEMUPRECFG%
guicontrolget,nicktst,,LCORE
if (SK_MODE = 1)
	{
		cfginif= Assignments.ini
		cfginik= ASSIGNMENTS
		cfgemc= %LCORE%
	}
IniRead,nicktstj,%cfginif%,%cfginik%,%cfgemc%
stringsplit,splcr,LCORE,_
EMUSN= %splcr1%
Loop,parse,supguiitems,|
	{
		if (A_loopField = "")
			{
				continue
			}
		if (A_Loopfield = EMUSN)
			{
				svgbrnv=
				guicontrol,enable,OPNCORE
				goto, %EMUSN%_GUI
			}
	}
;{;;;;;;;; get emulator from nickname ;;;;;;;
if (SK_MODE = 1)
	{
		SplitPath,nicktstj,tmpmund,tmpunp,,tmpunn
		splitpath,tmpunp,tmpunj
		stringreplace,tmpunn,tmpunn,x32,,
		stringreplace,tmpunn,tmpunn,x64,,
		stringreplace,tmpunn,tmpunn,32,,
		stringreplace,tmpunn,tmpunn,64,,
		Loop, Parse, EmuPartSet,`n`r
			{
				emuidnt1=
				emuidnt3=
				stringsplit,emuidnt,A_LoopField,=
				if ((emuidnt1 = tmpunn)&&(tmpunj = tmpunn))
					{
						nicktstk= %emuidnt1%
						break
					}
				if (emuidnt3 = tmpmund)
					{
						nicktstk= %emuidnt1%
						break
					}
			}
		if (nicktstk <> "")
			{
				svgbrnv=
				guicontrol,enable,OPNCORE
				EMUSN= %nicktstk%
				guito= %nicktstk%
				ifnotinstring,supgui,%guito%
					{
						guito= unimp
					}
				goto, %guito%_GUI
			}
	}
subemuname:
if (nicktstk <> "")
	{
		subemuname= %nicktstk%
	}
if (subemuname <> "")
	{
		SplitPath,nicktstj,EMUFN,EMUL,EMUXTYP,EMUSN,EMUDRV
		Loop, Parse, EmuPartSet,`n`r
			{
				jemun1=
				StringSplit,jemun,A_LoopField,=,"
				;"
				if (jemun1 = "")
					{
						continue
					}
				StringReplace,EMUFNS,EMUSN,-,,All
				StringReplace,EMUFNS,EMUFNS,%A_Space%,,All
				if ((jemun1 = EMUSN)&&(EMUSN <> ""))
					{
						svgbrnv=
						guicontrol,enable,OPNCORE
						ifinstring,supgui,%EMUFNS%
							{
								goto, %EMUFNS%_GUI
							}
						gosub, ShowOnlyEmuGui
					}
			}
	}
;};;;;;;;;
guicontrol,enable,OPNCORE
return
