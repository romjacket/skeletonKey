										stringreplace,curomcpl,curomcpl,[MEM],.mem,All	
										FileAppend,%curomcpl%,%RJSYSTEMS%\%curjf%\%curomfd%\%curininx%
									}
							}
					}
				If (RJKEYMON = 1)
					{
						if (RJMP1LC = 1)
							{
								curjoyf= %curjf%
								if (RJMAP1ROFTYP = 0)
