curovn=
EMEDTNX=
if (optn = "")
	{
		EMEDTNX.= ":" . "|" . EMOPV
	}
if (optn <> "")
	{
		Loop, Parse, EMOPV,|
			{
				if (A_LoopField = "")
					{
						continue
					}
				opvn+=1
				if (opvn = optn)
					{
						opvn+=1
						curovn:= opvn
						EMEDTNX.= A_LoopField . "|" . ":" . "|"
						continue
					}
				EMEDTNX.= A_LoopField . "|"
			}
	}
EMOPV= %EMEDTNX%
