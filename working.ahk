										curjoyf= All
									}
								FileCopy, rj\joyCfgs\%RJKEYMAPPER%\%joysubt%\%curjoyf%\Player1.*,%RJSYSTEMS%\%curjf%\%curomfd%,%RJKEYOW%
							}
						if (RJMP1LC = "")
							{
								FileCopy, %RJMAP1P%,%RJSYSTEMS%\%curjf%\%curomfd%,%RJKEYOW%
							}
						if (RJMP2LC = 1)
							{
								curjoyf= %curjf%
								if (RJMAP2ROFTYP = 0)
									{
										joysubt= Joystick
									}
								if (RJMAP2ROFTYP = 1)
									{
