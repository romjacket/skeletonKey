	{
		stringsplit,fii,A_LoopField,=
		stringsplit,gii,fii2,+
		cmdria= %fii1%
		stringreplace,cmdriv,cmdria,.,_,All
		stringreplace,medcmd,cmdriv,command,medcmd,All
		stringsplit,fea,cmdria,.
		ifinstring,fea1,command
			{
				ifinstring,mednafsc,fea2
