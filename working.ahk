									}
								if (FECHKC = 1)
									{
										ALHERE=
									}
								ifExist, %BOXPNG%
									{
										if (ALHERE = "")
											{
												RunWait, %comspec% /c " bin\any2ico.exe "-img=%BOXPNG%" "-icon=%cvtico%" -formats=32`,48`,96`,128`,256 -pngc -stretch ",,hide
												FileSetAttrib,+H,%cvtico%,2
											}
									}
								ifNotExist, %BOXPNG%
									{
										cvtico= %CICOLOC%\%curms%\%curms%.ico
									}
