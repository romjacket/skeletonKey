					}
				gameoverdcfg= -c "%curcfg%"
				Loop,Read,cores.ini
					{
						corelist .= (A_Index == 1 ? "" : "|") . A_LoopReadLine
					}
			}
		splitpath,romf,romtitle,rompth,inputext,romname,inputdrv
		if (RUNCOREOVERRIDE = "")
			{
				gosub, extensionlookup
			}
		if (CHOSEN = "")
			{
				guicontrol,,LCORE,|%coreselv%||%runlist%
				gosub,SUBLNCH
			}
		CHOSEN=
		return
	}
