				guicontrol,,emuRAD5C,%msplke%
				MEDemuRAD5C= %msplke%
				continue
			}
		if (msplkv = "tblur.accum.amount")
			{
				guicontrol,,emuEDTF,%msplke%
				guicontrol,,emuSLDB,%msplke%
				MEDemuEDTF= %msplke%
