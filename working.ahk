										break
									}
								if (BOXPNG = ":")
									{
										BOXPNG= [INS]
									}
							}
						ifInString,CBOXLOC,:
							{
								ifexist,%CBOXLOC%\%curms%\%batn%.png
									{
										BOXPNG= %CBOXLOC%\%curms%\%batn%.png
									}
								if (FECHKF = 1)
									{
										if (BOXPNG = ":")
											{
												Loop, %CBOXLOC%\%curms%\%batsrch%*.png
													{
														BOXPNG= %A_LoopFileFullPath%
														break
													}
											}
									}
							}
						if (FECHKA = 1)
							{
								cvtico= %CICOLOC%\%curms%\%batn%.ico
								if (ICJAK = 1)
									{
										cvtico= %batd%\%batn%.ico
									}
								ifExist, %cvtico%
									{
