																				{
																					if (FLBND = 6)
																						{
																							cnimp.= cnimp . "|" . "...more..."
																						}
																						continue
																				}
																			FLBND+=1
																			cnimp.= A_LoopFileFullPath . "|"
																		}
															}
												}
										}
