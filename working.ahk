							{
								FileCopy,%curcfg%,%curcfg%.bak,1
							}
						gosub, ApndOpt
						return
				}
			gosub, ApndOpt
			return
		}
msgbox,4,Warning, This is not a skeletonKey configuration`nWould you like to use this file anyway?
ifmsgbox, yes
	{
		gosub ApndOpt
		return
	}
		ifmsgbox, no
			{
				NwCfgFile=
			}
return
