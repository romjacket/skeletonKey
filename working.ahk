;{;;;;;;;;;;;;;;;;;;;;;;;;;;;   ES INITIALIZE   ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
iniread,EmulationStation,apps.ini,HTPC_FRONTENDS,EmulationStation
